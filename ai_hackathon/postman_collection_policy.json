{
  "info": {
    "name": "Insurance Policy Provider API",
    "description": "Collection to test the insurance policy provider platform — auth, admin upload, user queries.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Public",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health/",
              "host": ["{{base_url}}"],
              "path": ["health", ""]
            }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('token', json.token); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login/",
              "host": ["{{base_url}}"],
              "path": ["auth", "login", ""]
            }
          }
        },
        {
          "name": "Current User",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/me/",
              "host": ["{{base_url}}"],
              "path": ["auth", "me", ""]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/logout/",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout", ""]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Upload Policy PDF (tier_id required)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "tier_id",
                  "value": "1",
                  "type": "text",
                  "description": "ID of the PolicyTier to attach this PDF to"
                },
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Select an insurance policy PDF file"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/upload-policy/",
              "host": ["{{base_url}}"],
              "path": ["upload-policy", ""]
            }
          }
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "Dashboard",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/dashboard/",
              "host": ["{{base_url}}"],
              "path": ["dashboard", ""]
            }
          }
        },
        {
          "name": "My Policies",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/my-policies/",
              "host": ["{{base_url}}"],
              "path": ["my-policies", ""]
            }
          }
        },
        {
          "name": "Policy Detail (id=1)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/my-policies/1/",
              "host": ["{{base_url}}"],
              "path": ["my-policies", "1", ""]
            }
          }
        },
        {
          "name": "Scoped Query (policy id=1)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"What is my excess amount?\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/my-policies/1/query/",
              "host": ["{{base_url}}"],
              "path": ["my-policies", "1", "query", ""]
            }
          }
        },
        {
          "name": "Recommendations",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/recommendations/",
              "host": ["{{base_url}}"],
              "path": ["recommendations", ""]
            }
          }
        },
        {
          "name": "Query (auto-route across all policies)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"What does my car policy cover for third party liability?\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/query/",
              "host": ["{{base_url}}"],
              "path": ["query", ""]
            }
          }
        },
        {
          "name": "Query (With Chat History)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"What is the maximum claim amount for that?\",\n  \"chat_history\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"What does this policy cover for third party liability?\"\n    },\n    {\n      \"role\": \"assistant\",\n      \"content\": \"The policy covers third-party property damage.\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/query/",
              "host": ["{{base_url}}"],
              "path": ["query", ""]
            }
          }
        }
      ]
    }
  ]
}
