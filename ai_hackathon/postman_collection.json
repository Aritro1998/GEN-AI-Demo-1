{
  "info": {
    "_postman_id": "1f4d7a25-8d48-4f63-81fc-8ed5cf6be001",
    "name": "AI Hackathon Backend API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for the Django + DRF multimodal backend."
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "audio_file",
      "value": "/absolute/path/to/issue-note.wav"
    },
    {
      "key": "image_file",
      "value": "/absolute/path/to/error-screen.png"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/health/",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "health",
            ""
          ]
        }
      },
      "response": []
    },
    {
      "name": "Process Request",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "text",
              "value": "Users report checkout failures after a deployment. Investigate the issue using the supplied context.",
              "type": "text"
            },
            {
              "key": "audio",
              "type": "file",
              "src": "{{audio_file}}"
            },
            {
              "key": "images",
              "type": "file",
              "src": "{{image_file}}"
            }
          ]
        },
        "url": {
          "raw": "{{base_url}}/api/process/",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "process",
            ""
          ]
        },
        "description": "Send typed input with optional audio and screenshot files."
      },
      "response": []
    },
    {
      "name": "Add Knowledge Entry",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Checkout 502 after deploy\",\n  \"summary\": \"Users hit 502 errors after a new release.\",\n  \"description\": \"Ingress pointed to a missing service port after deployment. Rolling back and correcting the service mapping resolved it.\",\n  \"category\": \"Network\",\n  \"notes\": \"Reviewed manually during testing.\",\n  \"source\": \"manual\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/knowledge/",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "knowledge",
            ""
          ]
        }
      },
      "response": []
    },
    {
      "name": "Promote Reviewed Output",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Worker memory growth after queue spike\",\n  \"summary\": \"Background workers exhausted memory after a burst of jobs.\",\n  \"description\": \"The most likely cause was unbounded in-memory batching combined with delayed worker recycling.\",\n  \"category\": \"Memory\",\n  \"notes\": \"Promoted from a reviewed successful run.\",\n  \"final_output\": \"Mitigation: reduced batch size, restarted workers, and added memory alerts.\",\n  \"source\": \"promoted_output\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/knowledge/promote/",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "knowledge",
            "promote",
            ""
          ]
        }
      },
      "response": []
    }
  ]
}
